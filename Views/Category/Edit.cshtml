@model HotelG2.Models.LoanCategory

@{
    ViewData["Title"] = "Edit";
}
<h1>Edit</h1>

<h4>LoanCategory</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" asp-route-LoanCategoryID="@Model.LoanCategoryID">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="LoancategoryCode" class="control-label"></label>
                <input asp-for="LoancategoryCode" class="form-control" />
                <span asp-validation-for="LoancategoryCode" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DesInKhmer" class="control-label"></label>
                <input asp-for="DesInKhmer" class="form-control" />
                <span asp-validation-for="DesInKhmer" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Code" class="control-label"></label>
                <input asp-for="Code" class="form-control" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>
            <!-- Is Active -->
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsActive" />
                    Is Active
                </label>
            </div>

            <!-- Edit Sequence -->
            <div class="form-group">
                <label asp-for="EditSeq" class="control-label"></label>
                <input asp-for="EditSeq" class="form-control" />
                <span asp-validation-for="EditSeq" class="text-danger"></span>
            </div>

            <!-- Created DateTime -->
            <div class="form-group">
                <label asp-for="CreatedDT" class="control-label"></label>
                <input asp-for="CreatedDT" type="datetime-local" class="form-control" />
                <span asp-validation-for="CreatedDT" class="text-danger"></span>
            </div>

            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsActive" />
                    @Html.DisplayNameFor(model => model.IsActive)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a class="btn btn-warning" asp-action="Index">Back to List</a>
</div>
